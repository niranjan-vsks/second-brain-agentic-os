# ============================================================
# operator_os — environment variables
# Copy to .env.local and fill. Only DATABASE_URL + BETTER_AUTH_SECRET
# are required to boot; everything else unlocks a specific subsystem
# and degrades gracefully (configurable stub) when missing.
# ============================================================

# --- REQUIRED: core app ---
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
BETTER_AUTH_SECRET= # generate: openssl rand -base64 32

# --- LLM BRAIN (flexible provider seam + TIERED MODEL ROUTING, lib/llm.ts) ---
# Priority: OPENROUTER_API_KEY > LLM_BASE_URL > Vercel AI Gateway (default).
# Option A: OpenRouter (e.g. GLM, set LLM_MODEL* to OpenRouter model slugs)
OPENROUTER_API_KEY=
# Option B: any OpenAI-compatible endpoint (Together, Fireworks, local, etc.)
LLM_BASE_URL=
LLM_API_KEY=
#
# TIERED ROUTING: every agent task is mapped to a tier (light | standard | heavy)
# in code (see lib/model-router.ts for the registry). Set per-tier model IDs to
# control cost — or set only the base var to run everything on one model.
#
# Gateway tier overrides (defaults: light=google/gemini-2.5-flash-lite,
# standard=google/gemini-2.5-flash, heavy=anthropic/claude-sonnet-4.5):
GATEWAY_MODEL_LIGHT=
GATEWAY_MODEL_STANDARD=
GATEWAY_MODEL_HEAVY=
GATEWAY_MODEL= # single-model fallback for all tiers
# OpenRouter/custom tier overrides (each falls back to LLM_MODEL):
LLM_MODEL_LIGHT=
LLM_MODEL_STANDARD=
LLM_MODEL_HEAVY=
LLM_MODEL=

# --- GOOGLE OAUTH (shared: YouTube pipeline + Jarvis Google Calendar) ---
# One Google Cloud project serves both — enable the YouTube Data API and the
# Google Calendar API, and register BOTH callback URLs:
#   /api/auth/youtube/callback and /api/auth/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI= # e.g. https://your-app.vercel.app/api/auth/youtube/callback
# Encrypts OAuth refresh tokens at rest (AES-256-GCM). Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# --- VIDEO GENERATION (Higgsfield, lib/higgsfield.ts stub until set) ---
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_URL= # optional; defaults to the official endpoint when key is set

# --- STORAGE (Vercel Blob; auto-set when the Blob integration is added) ---
BLOB_READ_WRITE_TOKEN=

# --- REMOTION RENDERING (edit engine; stub until set) ---
REMOTION_RENDER_URL= # your deployed Remotion render service endpoint
REMOTION_RENDER_SECRET=

# --- TELEGRAM BOT (chat interface mirror) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID= # your numeric Telegram user id (single-operator security)

# --- CAREER INTELLIGENCE: WEB SEARCH (lib/search.ts seam; deep research + agent scan) ---
# Provider-agnostic: tavily | brave | serper | crawl4ai. Until set, `deep` falls back
# to generating a copy-paste research prompt (original career-ops behavior).
SEARCH_PROVIDER=
SEARCH_API_KEY=
# crawl4ai only: base URL of your self-hosted crawl4ai instance (same one used by LinkedIn OS patterns)
CRAWL4AI_BASE_URL=

# --- CAREER INTELLIGENCE: BROWSER WORKER (lib/career/browser-worker.ts stub until set) ---
# One worker seam covers: resume/cover-letter PDF render, scan verification, portal snapshots (Block G)
BROWSER_WORKER_URL=
BROWSER_WORKER_SECRET=

# --- LEAD-GEN AGENT (Freelance Funnel; also settable via Settings -> API Keys) ---
# Google Places API key for "businesses without websites" discovery.
# Resolution order: stored key in Settings API vault > this env var.
GOOGLE_MAPS_API_KEY=
# Web-search discovery reuses SEARCH_PROVIDER/SEARCH_API_KEY above (or vault keys:
# tavily / brave / serper stored per-provider in Settings -> API Keys).

# --- META ADS FUNNEL SEAM (Settings -> Funnels; config-only until campaign push is built) ---
META_ADS_ACCESS_TOKEN=

# --- CRON SECURITY (protects /api/cron/* routes) ---
CRON_SECRET= # generate: openssl rand -hex 16
